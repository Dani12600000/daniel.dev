    {
      "id": "movemaster",
      "n": "01",
      "title": "Movemaster",
      "subtitle": "Chess assistant — move suggestion overlay",
      "tagline": "Real-time chess analysis, inline.",
      "year": "2024",
      "role": "Design + Engineering",
      "timeline": "3 months",
      "stack": [
        "TypeScript",
        "Stockfish.js",
        "Chrome ext"
      ],
      "tag": "hobby",
      "img": "/assets/movemaster-logo.png",
      "desc": "A browser extension that analyzes live chess positions and overlays suggested moves directly on chess.com.",
      "links": {
        "github": "github.com/Dani12600000/movemaster",
        "live": null
      },
      "caseStudy": {
        "sections": [
          {
            "num": "01",
            "title": "Problem",
            "body": "Learning chess openings means cross-referencing an engine constantly. Context-switching to a second tab kills the flow. I wanted the engine's suggestion to sit inline, non-intrusively, while I play."
          },
          {
            "num": "02",
            "title": "Approach",
            "body": "A Chrome extension hooks into the board DOM, hashes the position into FEN, and pipes it to a local Stockfish worker. The suggested move renders as a translucent arrow overlay — always present, never blocking input.",
            "code": {
              "lang": "ts",
              "filename": "content-script.ts",
              "tokens": [
                {
                  "t": "// content-script.ts",
                  "c": "comment"
                },
                {
                  "t": "\n",
                  "c": "plain"
                },
                {
                  "t": "const",
                  "c": "keyword"
                },
                {
                  "t": " fen = ",
                  "c": "plain"
                },
                {
                  "t": "parseBoard",
                  "c": "fn"
                },
                {
                  "t": "(document);\n",
                  "c": "plain"
                },
                {
                  "t": "const",
                  "c": "keyword"
                },
                {
                  "t": " best = ",
                  "c": "plain"
                },
                {
                  "t": "await",
                  "c": "keyword"
                },
                {
                  "t": " stockfish.",
                  "c": "plain"
                },
                {
                  "t": "analyse",
                  "c": "fn"
                },
                {
                  "t": "(fen, ",
                  "c": "plain"
                },
                {
                  "t": "depth",
                  "c": "arg"
                },
                {
                  "t": ": ",
                  "c": "plain"
                },
                {
                  "t": "18",
                  "c": "num"
                },
                {
                  "t": ");\n",
                  "c": "plain"
                },
                {
                  "t": "overlay",
                  "c": "fn"
                },
                {
                  "t": ".",
                  "c": "plain"
                },
                {
                  "t": "drawArrow",
                  "c": "fn"
                },
                {
                  "t": "(best.from, best.to);",
                  "c": "plain"
                }
              ]
            }
          },
          {
            "num": "03",
            "title": "Build",
            "bullets": [
              "Stockfish compiled to WASM — ships in the extension bundle.",
              "MutationObserver tracks board state without polling.",
              "SVG arrow overlay, inset to match chess.com's square size."
            ]
          },
          {
            "num": "04",
            "title": "Outcome",
            "body": "Works end-to-end. Latency under 200ms for depth-18 analysis on a mid-range laptop. Built purely as a learning exercise — obviously, I don't use it in ranked games."
          }
        ]
      }
